# =========================================================
# Contento — environment variables
# Copy this file to `.env` at the project root and fill in.
# =========================================================

# ---------- server ----------
PORT=4000
NODE_ENV=development
SESSION_SECRET=change-me-please

# Where the backend reaches itself when redirecting OAuth flows
BASE_URL=http://localhost:4000

# ---------- database ----------
DB_PATH=./backend/data/contento.db

# ---------- YouTube Data API v3 ----------
# https://console.cloud.google.com/apis/credentials
# Create an OAuth client (Web app). Add the redirect URI below to "Authorized redirect URIs":
#   http://localhost:4000/api/auth/youtube/callback
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REDIRECT_URI=http://localhost:4000/api/auth/youtube/callback

# ---------- TikTok for Developers ----------
# https://developers.tiktok.com
# Add this URL under "Redirect domain":
#   http://localhost:4000/api/auth/tiktok/callback
TT_CLIENT_KEY=
TT_CLIENT_SECRET=
TT_REDIRECT_URI=http://localhost:4000/api/auth/tiktok/callback

# ---------- Meta (Instagram Graph API) ----------
# https://developers.facebook.com/apps
# Use Instagram Graph API; you need a Business or Creator account linked to a Facebook page.
#   http://localhost:4000/api/auth/instagram/callback
IG_CLIENT_ID=
IG_CLIENT_SECRET=
IG_REDIRECT_URI=http://localhost:4000/api/auth/instagram/callback

# ---------- Claude (AI content ideas) ----------
# https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ---------- Sync schedule ----------
# Cron expression for periodic metric sync
SYNC_CRON=*/30 * * * *
